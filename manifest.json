{
  "manifest_version": 3,
  "name": "YouTube Side Panel",
  "version": "16.0.0",
  "description": "Adds a draggable side panel to YouTube watch pages with tabs for description, comments, YCS (Comment Search), chapters, and more. Works across SPA navigations.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "content/core.js",
        "content/prefs.js",
        "content/panels.js",
        "content/tabs.js",
        "content/tab-bar.js",
        "content/layout.js",
        "content/navigation.js",
        "content/drag.js",
        "content/notification-ontop.js",
        "content/index.js"
      ],
      "css": ["content.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
